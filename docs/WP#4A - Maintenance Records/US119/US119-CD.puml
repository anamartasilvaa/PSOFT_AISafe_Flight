MaintenanceRecordService .down.> MaintenanceRecordViewDTO : creates >

MaintenanceRecordRepository .down.> MaintenanceRecord : reads/saves >
MaintenanceRecord "1" --> "1" MaintenanceStatus : uses >
@enduml