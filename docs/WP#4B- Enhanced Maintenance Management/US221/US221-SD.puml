@startuml
title US221-SD
autonumber
actor "Maintenance Technician" as Tech
participant ":MaintenanceController" as Ctrl
participant ":MaintenanceService" as Service
participant ":MaintenanceRecordRepository" as Repo
participant "dto:TurnaroundTimeDTO" as DTO

activate Tech
Tech -> Ctrl : GET /api/maintenance/statistics/turnaround
activate Ctrl

Ctrl -> Service : getTurnaroundTimePerAircraftModel()
activate Service

Service -> Repo : findByStatus(COMPLETED)
activate Repo
Repo --> Service : List<MaintenanceRecord>
deactivate Repo

Service -> Service : group by model && calculate average
Service -> DTO ** : create (map modelName + avgHours)
Service --> Ctrl : List<TurnaroundTimeDTO>
deactivate Service

Ctrl --> Tech : 200 OK\n(CollectionModel<EntityModel<TurnaroundTimeDTO>>)
deactivate Ctrl
deactivate Tech
@enduml